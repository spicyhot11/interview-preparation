        <mxCell id="vWTF2GvCP_Uw3qWAGXaK-55" parent="vWTF2GvCP_Uw3qWAGXaK-54" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;5&lt;/font&gt;" vertex="1">
