          <mxGeometry height="60" width="120" x="85" y="1130" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-42" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="return_value&lt;div&gt;这里保存需要返回的数据，在变量中&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="690" y="830" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-43" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="到这一步，我们的代码业务逻辑已经执行完成。后续的挂起只是为了确保在父协程读取之前子协程不要释放" vertex="1">
          <mxGeometry height="55" width="280" x="827" y="835" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-50" edge="1" parent="1" source="6FXj73WVG-HMQLctZvdy-48" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="1280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-48" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Task 离开作用域" vertex="1">
          <mxGeometry height="60" width="120" x="85" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-51" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="final_suspend挂起的可等待对象销毁，子协程释放（析构函数完成）" vertex="1">
          <mxGeometry height="60" width="120" x="680" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-52" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeWidth=3;dashed=1;strokeColor=#FF8000;" value="" vertex="1">
          <mxGeometry height="1450" width="190" x="50" y="-70" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 0, 0); font-size: 20px;&quot;&gt;父协程&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="100" x="50" y="-60" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 0, 0); font-size: 20px;&quot;&gt;子协程&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="100" x="680" y="-60" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-58" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;两者只是函数执行的切换，没有进行异步调用&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;如果需要异步调用，应当自行在子协程中进行异步操作。如果需要等待的话，可将异步操作也包装为一个awaiter， 并在suspend时将上级协程句柄传递给回调函数，由回调函数触发h.resume，使得co_await可以等待&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="550" x="50" y="-230" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-59" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Awaiter&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 17px;&quot;&gt;awaiter 是给执行 co_await 的协程用的,告诉他怎么去等待&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="140" width="290" x="680" y="-250" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-60" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;promise_type&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;font-size: 17px;&quot;&gt;给子协程使用，规定在子协程在执行自己的生命周期不同阶段要做的事&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="140" width="290" x="1040" y="-250" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-62" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="coroutine_handle.destroy()，需调用这个，一般会放在析构函数中确保释放" vertex="1">
          <mxGeometry height="30" width="130" x="870" y="1265" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
