        <mxCell id="vWTF2GvCP_Uw3qWAGXaK-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 15px; color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;大端的操作系统，会将内存中的多字节类型，按照高位低地址的类型排布。所以直接放入报文的话是这样的&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="300" x="-120" y="-230" as="geometry" />
        </mxCell>
        <mxCell id="vWTF2GvCP_Uw3qWAGXaK-62" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 15px; color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;小端的操作系统，会将内存中的多字节类型，按照低位低地址的类型排布。所以直接放入报文的话是这样的&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="300" x="-110" y="40" as="geometry" />
        </mxCell>
        <mxCell id="vWTF2GvCP_Uw3qWAGXaK-63" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font color=&quot;#ff3333&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;b&gt;char是单字节表示，在内存中逐个排列。所以不受大小端影响&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="300" x="-90" y="370" as="geometry" />
        </mxCell>
        <mxCell id="vWTF2GvCP_Uw3qWAGXaK-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font color=&quot;#ff3333&quot;&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;&lt;b&gt;大端小端影响的是一种数据类型在内存中的排列顺序，但是对于类型之间的排布，还是按照先来的放在低地址进行排列&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="670" x="250" y="-320" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
