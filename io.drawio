        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-35" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="child_await::&amp;nbsp;&lt;div&gt;await_resume。返回运行结果&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="130" x="80" y="980" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-38" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="这里一定注意&amp;nbsp; 返回的awaiter必须挂起，或者返回std::suspend_always。不然子协程将立即释放" vertex="1">
          <mxGeometry height="75" width="250" x="840" y="982.5" as="geometry" />
        </mxCell>
        <mxCell id="6FXj73WVG-HMQLctZvdy-49" edge="1" parent="1" source="6FXj73WVG-HMQLctZvdy-41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="6FXj73WVG-HMQLctZvdy-48">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
